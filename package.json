{
  "name": "paginator",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && bun scripts/fix-dts-extensions.ts",
    "build:demo": "tsc && vite build",
    "preview": "vite preview",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "jszip": "^3.10.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@types/pdfkit": "^0.17.6",
    "buffer": "^6.0.3",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.19.1",
    "qrcode-generator": "^2.0.4",
    "svg-to-pdfkit": "^0.1.8"
  }
}